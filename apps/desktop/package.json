{
  "name": "@app/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "electron dist-electron/main.cjs",
    "package": "bun run build && electron-builder --config electron-builder.config.cjs",
    "package:mac": "bun run build && electron-builder --mac --config electron-builder.config.cjs",
    "package:win": "bun run build && electron-builder --win --config electron-builder.config.cjs",
    "package:linux": "bun run build && electron-builder --linux --config electron-builder.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron": "^33.0.0",
    "node-global-key-listener": "^0.3.0"
  },
  "devDependencies": {
    "@app/contracts": "workspace:*",
    "@types/node": "^22.0.0",
    "electron-builder": "^25.1.8",
    "tsdown": "^0.20.3",
    "typescript": "^5.6.0"
  },
  "build": {
    "productName": "Murmur"
  }
}
