# GitHub release upload token. Needs repo access for thatbeautifuldream/murmur.
GH_TOKEN=ghp_replace_with_token

# Public macOS release signing/notarization. release:mac defaults this to 1.
MURMUR_NOTARIZE=1

# Apple notarization credentials. Use an app-specific password, not your Apple ID password.
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=ABCDE12345

# Optional: force a specific Developer ID Application certificate.
# CSC_NAME="Developer ID Application: Your Name (ABCDE12345)"
