{
  "name": "murmur",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:web dev:desktop",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:desktop": "VITE_DEV_SERVER_URL=http://localhost:5173 bun run --cwd apps/desktop dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "start": "bun run --cwd apps/desktop start",
    "package": "turbo run build && bun run --cwd apps/desktop package"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
